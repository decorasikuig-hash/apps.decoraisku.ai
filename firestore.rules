rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Rules for each collection
    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(itemId);
    }

    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(projectId);
    }

    match /employees/{employeeId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(employeeId);
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(transactionId);
    }

    match /attendance/{logId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(logId);
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(settingId);
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(notifId);
    }

    match /customers/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /suppliers/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /vehicles/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /equipments/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /toolLoans/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /materialRequests/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /purchaseOrders/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /purchaseInvoices/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /goodsReceipts/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /surveys/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /quotations/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /salesInvoices/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /salaries/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /cashAdvances/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /craftsmanReports/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /bank_accounts/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /bank_mutations/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /categories/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /warehouses/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /catalogProducts/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /weeklyPayrolls/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /users/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /roles/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /stockLedgers/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }

    match /customUnits/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
    }
  }
}
